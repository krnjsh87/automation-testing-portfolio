  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "winston": "^3.19.0"
  }
}
