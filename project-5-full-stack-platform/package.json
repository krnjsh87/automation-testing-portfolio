    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "full-stack",
    "test-platform",
    "playwright",
    "k6",
    "performance-testing",
    "orchestration",
    "lambdatest"
  ],
