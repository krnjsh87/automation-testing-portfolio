{
  "name": "project-5-full-stack-platform",
  "version": "1.0.0",
  "description": "Full-stack test automation platform with E2E, API, and performance testing orchestration",
  "main": "src/core/TestOrchestrator.ts",
  "scripts": {
    "test": "npx playwright test",
    "test:e2e": "npx playwright test",
    "test:k6": "k6 run src/performance/k6/load-test.js",
