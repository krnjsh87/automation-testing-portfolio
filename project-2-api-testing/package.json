{
  "name": "project-2-api-testing",
  "version": "1.0.0",
  "description": "REST API testing suite with Playwright, TypeScript, and Python demonstrating CRUD operations and contract testing",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:users": "npx playwright test users-api",
    "test:products": "npx playwright test products-api",
    "test:orders": "npx playwright test orders-api",
    "report": "npx playwright show-report",
    "python:test": "python -m unittest discover scripts/python -v"
  },
  "keywords": [
    "api-testing",
    "rest-api",
    "playwright",
    "automation-testing",
    "typescript",
    "python"
  ],
  "author": "Karan",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
